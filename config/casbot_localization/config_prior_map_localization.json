{
  "prior_map_localization": {
    // ⚠️ 必填：先验地图 PCD 路径(绝对路径)
    "prior_map_path": "/CHANGE/ME/prior_map.pcd",
    "assume_gravity_aligned": true,   // 地图须 z-up 重力对齐(MVP 仅声明;false 时告警)

    "voxel_resolution": 0.5,
    "min_overlap": 0.05,              // 滞回进入阈值;退出阈值 = 0.8x
    "s2m_points_ratio": 1.0,          // source 随机子采样比例 = S2M 强度旋钮
    "s2m_num_threads": 4,

    "relocalization_cooldown_sec": 5.0, // 启动时抬到 >= smoother_lag + margin

    // 初始位姿:2D /initialpose 补全为 6DoF(z 查地图、roll/pitch 取 IMU)
    // has_default_init_pose=true 则用 default_init_pose[x,y,z,yaw],否则等 /initialpose
    "has_default_init_pose": false,
    "default_init_pose": [0, 0, 0, 0],
    "ground_grid_resolution": 1.0,
    "imu_height_above_ground": 0.0,

    // 帧名(须与 config_ros.json 的 glim_ros.*_frame_id 一致)
    "map_frame_id": "map",
    "odom_frame_id": "odom",

    // --- v2 预留(MVP 不读取) ---
    "max_corr_dist": 1.0,
    "full_weight_overlap": 0.30,
    "use_gpu": false
  }
}
